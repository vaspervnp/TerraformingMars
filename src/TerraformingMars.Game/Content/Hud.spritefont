<?xml version="1.0" encoding="utf-8"?>
<!--
  SpriteFont για το HUD. Χρησιμοποιεί Consolas (monospaced, διαθέσιμο στα Windows) ώστε
  οι αριθμοί/πόροι να ευθυγραμμίζονται. Compiled από το MonoGame Content Pipeline (mgcb).
-->
<XnaContent xmlns:Graphics="Microsoft.Xna.Framework.Content.Pipeline.Graphics">
  <Asset Type="Graphics:FontDescription">
    <FontName>Consolas</FontName>
    <Size>14</Size>
    <Spacing>0</Spacing>
    <UseKerning>true</UseKerning>
    <Style>Regular</Style>
    <DefaultCharacter>?</DefaultCharacter>
    <CharacterRegions>
      <CharacterRegion>
        <Start>&#32;</Start>
        <End>&#126;</End>
      </CharacterRegion>
    </CharacterRegions>
  </Asset>
</XnaContent>
