<?xml version="1.0" encoding="utf-8"?>
<!-- Repo-scoped feed: το μηχάνημα έχει ένα σπασμένο global FastReport source (403) που
     ρίχνει το restore. Εδώ περιοριζόμαστε στο nuget.org (MonoGame, NAudio, xunit κ.λπ.). -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
